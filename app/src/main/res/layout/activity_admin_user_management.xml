<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light"
    tools:context=".admin.AdminUserManagementActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Custom Toolbar Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="Go Back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="System User Roster"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Search Input Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="🔍 Search users by name or email..."
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- User Cards Container List -->
        <LinearLayout
            android:id="@+id/layout_user_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Dynamic User cards will be managed by code, but let's wire up mock visual layers for easy editing -->
            
            <!-- User 1: Rahul Kumar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_user_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Initial Avatar -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/primary_light"
                        android:text="RK"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tv_user_name_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Rahul Kumar"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_user_email_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="rahul@example.com"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                        <!-- Role Badge -->
                        <TextView
                            android:id="@+id/tv_user_role_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_social_button"
                            android:backgroundTint="@color/accent_green_light"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="STUDENT"
                            android:textColor="@color/accent_green"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Edit & Delete Buttons -->
                    <ImageButton
                        android:id="@+id/btn_edit_user_1"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_edit"
                        android:contentDescription="Edit User"
                        android:layout_marginEnd="4dp"/>

                    <ImageButton
                        android:id="@+id/btn_delete_user_1"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        android:contentDescription="Delete User"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User 2: Alice Williams -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_user_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Initial Avatar -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/accent_orange_light"
                        android:text="AW"
                        android:textColor="@color/accent_orange"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tv_user_name_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Alice Williams"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_user_email_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="alice@example.com"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                        <!-- Role Badge -->
                        <TextView
                            android:id="@+id/tv_user_role_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_social_button"
                            android:backgroundTint="@color/primary_light"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="MENTOR"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Edit & Delete Buttons -->
                    <ImageButton
                        android:id="@+id/btn_edit_user_2"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_edit"
                        android:contentDescription="Edit User"
                        android:layout_marginEnd="4dp"/>

                    <ImageButton
                        android:id="@+id/btn_delete_user_2"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        android:contentDescription="Delete User"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User 3: Mahesh Shinde -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_user_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Initial Avatar -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/accent_orange_light"
                        android:backgroundTint="#FFE2E8F0"
                        android:text="MS"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tv_user_name_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mahesh Shinde"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_user_email_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="mahesh@example.com"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                        <!-- Role Badge -->
                        <TextView
                            android:id="@+id/tv_user_role_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_social_button"
                            android:backgroundTint="#FEE2E2"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="ADMIN"
                            android:textColor="@color/google_red"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Edit & Delete Buttons -->
                    <ImageButton
                        android:id="@+id/btn_edit_user_3"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_edit"
                        android:contentDescription="Edit User"
                        android:layout_marginEnd="4dp"/>

                    <ImageButton
                        android:id="@+id/btn_delete_user_3"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        android:contentDescription="Delete User"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
